# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/daodent"

# Auth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="change-me-in-production"

# AI — чат-бот на лендинге (pick one or both)
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""

# Yandex SpeechKit — голосовой ввод для врачей
# Получить: https://console.cloud.yandex.ru/
YANDEX_SPEECHKIT_API_KEY=""
YANDEX_CLOUD_FOLDER_ID=""

# Email (optional)
POSTBOX_ACCESS_KEY_ID=""
POSTBOX_SECRET_ACCESS_KEY=""
EMAIL_FROM=""

# Social (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""
VK_ACCESS_TOKEN=""
VK_GROUP_ID=""

# Yandex Direct API — AI-маркетинг
# 1. Зарегистрировать приложение: https://oauth.yandex.ru/
# 2. Получить OAuth-токен: https://oauth.yandex.ru/authorize?response_type=token&client_id=YOUR_CLIENT_ID
# 3. Вставить токен в YANDEX_DIRECT_TOKEN
YANDEX_DIRECT_CLIENT_ID=""
YANDEX_DIRECT_CLIENT_SECRET=""
YANDEX_DIRECT_REDIRECT_URI="https://oauth.yandex.ru/verification_code"
YANDEX_DIRECT_LOGIN=""
YANDEX_DIRECT_TOKEN=""
