// ============================================
// Prisma Schema — Стоматологическая клиника ДаоДент
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Роли и пользователи
// ============================================

enum Role {
  OWNER    // Владелец клиники — полный доступ
  MANAGER  // Управляющий — расписание, CRM, отчёты, видео
  DOCTOR   // Врач — своё расписание, свои пациенты, зубная формула
  ADMIN    // Администратор ресепшна — CRM, запись, расписание всех врачей
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String
  role           Role      @default(ADMIN)
  avatarUrl      String?
  phone          String?
  specialization String?   // для врачей: терапевт, хирург, ортодонт и т.д.
  experience     String?   // стаж работы
  bio            String?   @db.Text // описание для карточки врача
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Связи
  appointments       Appointment[]   @relation("DoctorAppointments")
  patients           Patient[]       @relation("PatientDoctor")  // лечащий врач
  treatmentPlans     TreatmentPlan[] @relation("PlanDoctor")
  stockDocuments     StockDocument[]
  agentConversations AgentConversation[]
  plannerNotes       PlannerNote[]
  auditLogs          AuditLog[]

  @@map("users")
}

// ============================================
// Агент: история переписок (AI-ассистент)
// ============================================

model AgentConversation {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("Новый чат")
  messages    Json     @default("[]")
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("agent_conversations")
}

// ============================================
// Пациенты (центральная сущность CRM)
// ============================================

enum PatientStatus {
  NEW_LEAD          // Новая заявка
  CONTACTED         // Первый контакт
  APPOINTMENT_SCHEDULED  // Записан на приём
  VISITED           // Был на приёме
  TREATMENT_PLAN    // Составлен план лечения
  IN_TREATMENT      // На лечении
  TREATMENT_COMPLETED // Завершил лечение
  LOST              // Потерянный
}

enum PatientSource {
  WEBSITE         // Заявка с сайта
  PHONE           // Звонок
  WALK_IN         // Пришёл сам
  REFERRAL        // По рекомендации
  SOCIAL_MEDIA    // Соцсети
  YANDEX_DIRECT   // Яндекс.Директ
  YANDEX_MAPS     // Яндекс.Карты
  TWO_GIS         // 2ГИС
  MESSENGER       // Мессенджер
  OTHER           // Другое
}

model Patient {
  id              String        @id @default(cuid())
  firstName       String
  lastName        String
  middleName      String?       // отчество
  phone           String
  email           String?
  birthDate       DateTime?
  gender          String?       // М/Ж
  address         String?       // для географии пациентов
  status          PatientStatus @default(NEW_LEAD)
  source          PatientSource @default(OTHER)
  utmSource       String?       // UTM-метка
  utmMedium       String?
  utmCampaign     String?

  // Медицинские данные
  allergies       String?       @db.Text // аллергии
  chronicDiseases String?       @db.Text // хронические заболевания
  contraindications String?     @db.Text // противопоказания

  // Документы
  passportData    String?       // данные паспорта (зашифровано)
  insurancePolicy String?       // полис ОМС/ДМС
  consentSigned   Boolean       @default(false) // согласие на обработку данных

  // Связи
  doctorId        String?       // лечащий врач
  doctor          User?         @relation("PatientDoctor", fields: [doctorId], references: [id], onDelete: SetNull)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  appointments    Appointment[]
  treatmentPlans  TreatmentPlan[]
  dentalChart     ToothRecord[]
  medicalRecords  MedicalRecord[]
  notes           PatientNote[]
  payments        Payment[]
  leads           Lead[]
  documents       PatientDocument[]

  @@map("patients")
}

model PatientNote {
  id        String    @id @default(cuid())
  patientId String
  text      String    @db.Text
  callAt    DateTime? // время напоминания о звонке
  createdAt DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_notes")
}

model PatientDocument {
  id          String   @id @default(cuid())
  patientId   String
  name        String   // название документа
  type        String   // passport, insurance, consent, xray, photo, other
  fileUrl     String
  description String?
  createdAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_documents")
}

// ============================================
// Лиды (заявки с сайта/мессенджеров)
// ============================================

enum LeadChannel {
  WEBSITE_FORM    // Форма на сайте
  CALLBACK        // Обратный звонок
  PHONE_CALL      // Входящий звонок
  WHATSAPP        // WhatsApp
  TELEGRAM        // Telegram
  VK              // ВКонтакте
  QUIZ            // Квиз
  AI_CHAT         // AI-ассистент на сайте
  OTHER           // Другое
}

enum LeadStatus {
  NEW             // Новая заявка
  PROCESSING      // В обработке
  CONVERTED       // Конвертирована в пациента
  CLOSED          // Закрыта
}

model Lead {
  id              String      @id @default(cuid())
  patientId       String?
  channel         LeadChannel @default(OTHER)
  name            String?     // имя из формы
  phone           String?     // телефон из формы
  email           String?
  message         String?     @db.Text // сообщение/комментарий
  service         String?     // запрашиваемая услуга
  preferredDate   DateTime?   // желаемая дата приёма
  preferredDoctor String?     // желаемый врач
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  status          LeadStatus  @default(NEW)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@map("leads")
}

// ============================================
// Услуги клиники
// ============================================

model ServiceCategory {
  id        String    @id @default(cuid())
  name      String    // Терапия, Хирургия, Имплантация и т.д.
  slug      String    @unique
  icon      String?   // иконка
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  services  Service[]

  @@map("service_categories")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  categoryId  String
  price       Decimal  @db.Decimal(10, 2) // базовая цена
  priceMax    Decimal? @db.Decimal(10, 2) // максимальная цена (диапазон)
  durationMin Int      @default(30)       // длительность в минутах
  published   Boolean  @default(true)     // показывать на сайте
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       ServiceCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  treatmentSteps TreatmentStep[]

  @@map("services")
}

// ============================================
// Кабинеты клиники
// ============================================

enum CabinetStatus {
  FREE            // Свободен
  IN_SESSION      // Приём
  BREAK           // Перерыв
  STERILIZATION   // Стерилизация
}

model Cabinet {
  id        String        @id @default(cuid())
  name      String        // "Кабинет 1", "Кабинет 2", "Кабинет 3"
  number    Int           @unique // 1, 2, 3
  status    CabinetStatus @default(FREE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  appointments Appointment[]

  @@map("cabinets")
}

// ============================================
// Приёмы (записи на приём)
// ============================================

enum AppointmentStatus {
  SCHEDULED       // Запланирован
  CONFIRMED       // Подтверждён пациентом
  IN_PROGRESS     // Идёт приём
  COMPLETED       // Завершён
  CANCELLED       // Отменён
  NO_SHOW         // Не явился
}

enum AppointmentType {
  INITIAL_CONSULTATION  // Первичная консультация
  TREATMENT             // Лечебный приём
  FOLLOW_UP             // Контрольный визит
  EMERGENCY             // Экстренный приём
  PREVENTION            // Профилактика/гигиена
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  cabinetId   String?
  serviceId   String?
  type        AppointmentType   @default(INITIAL_CONSULTATION)
  status      AppointmentStatus @default(SCHEDULED)
  date        DateTime          @db.Date
  startTime   String            // "09:00" формат HH:mm
  endTime     String            // "09:30"
  duration    Int               @default(30) // минуты
  notes       String?           @db.Text // заметки к приёму
  diagnosis   String?           @db.Text // диагноз
  treatment   String?           @db.Text // проведённое лечение
  materials   String?           @db.Text // использованные материалы
  recommendations String?       @db.Text // рекомендации пациенту

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor   User     @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  cabinet  Cabinet? @relation(fields: [cabinetId], references: [id], onDelete: SetNull)
  service  Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  payment  Payment?

  @@index([doctorId, date])
  @@index([patientId, date])
  @@index([date, status])
  @@map("appointments")
}

// ============================================
// Зубная формула (интерактивная карта зубов)
// ============================================

enum ToothStatus {
  HEALTHY         // Здоров
  CARIES          // Кариес
  FILLED          // Пломба
  CROWN           // Коронка
  MISSING         // Отсутствует
  IMPLANT         // Имплант
  ROOT_CANAL      // Депульпирован
  BRIDGE          // Мостовидный протез
  PERIDONTAL      // Пародонтит
  EXTRACTION_NEEDED // Требует удаления
}

model ToothRecord {
  id          String      @id @default(cuid())
  patientId   String
  toothNumber Int         // международная нумерация 11-48 (ISO 3950)
  status      ToothStatus @default(HEALTHY)
  notes       String?     @db.Text
  updatedAt   DateTime    @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, toothNumber])
  @@map("tooth_records")
}

// ============================================
// Планы лечения
// ============================================

enum TreatmentPlanStatus {
  DRAFT           // Черновик
  PROPOSED        // Предложен пациенту
  APPROVED        // Одобрен пациентом
  IN_PROGRESS     // Выполняется
  COMPLETED       // Завершён
  CANCELLED       // Отменён
}

model TreatmentPlan {
  id          String              @id @default(cuid())
  patientId   String
  doctorId    String
  title       String              // "Лечение кариеса зубов 36, 37"
  description String?             @db.Text
  status      TreatmentPlanStatus @default(DRAFT)
  totalCost   Decimal             @default(0) @db.Decimal(10, 2)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  patient Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User            @relation("PlanDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  steps   TreatmentStep[]

  @@map("treatment_plans")
}

model TreatmentStep {
  id              String   @id @default(cuid())
  treatmentPlanId String
  serviceId       String?
  toothNumber     Int?     // номер зуба (если применимо)
  description     String   // описание шага
  order           Int      @default(0)
  cost            Decimal  @default(0) @db.Decimal(10, 2)
  completed       Boolean  @default(false)
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  treatmentPlan TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@map("treatment_steps")
}

// ============================================
// Медицинские записи (протокол приёма)
// ============================================

model MedicalRecord {
  id          String   @id @default(cuid())
  patientId   String
  date        DateTime @default(now())
  type        String   // consultation, treatment, xray, photo_protocol
  content     String   @db.Text  // содержание (может быть от голосового ввода)
  attachments Json?    // [{name, url, type}] — фото, рентгены
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, date])
  @@map("medical_records")
}

// ============================================
// Оплаты
// ============================================

enum PaymentStatus {
  PENDING     // Ожидает оплаты
  PAID        // Оплачено
  PARTIAL     // Частично оплачено
  REFUNDED    // Возврат
  CANCELLED   // Отменено
}

enum PaymentMethod {
  CASH        // Наличные
  CARD        // Карта
  TRANSFER    // Перевод
  INSTALLMENT // Рассрочка
}

model Payment {
  id            String        @id @default(cuid())
  patientId     String
  appointmentId String?       @unique
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @default(CARD)
  status        PaymentStatus @default(PENDING)
  description   String?
  receiptUrl    String?       // URL фискального чека
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@map("payments")
}

// ============================================
// Склад стоматологических материалов
// ============================================

enum ProductUnit {
  PCS   // штуки
  PACK  // упаковка
  ML    // миллилитры
  G     // граммы
  L     // литры
  KG    // килограммы
}

enum WarehouseType {
  MAIN    // основной склад
  CABINET // кабинет
}

enum StockDocumentType {
  RECEIPT    // приход
  WRITE_OFF  // расход
  TRANSFER   // перемещение
  INVENTORY  // инвентаризация
}

enum StockDocumentStatus {
  DRAFT
  POSTED
}

enum StockMovementType {
  RECEIPT
  SHIPMENT
  TRANSFER
  ADJUSTMENT
}

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  unit        ProductUnit @default(PCS)
  trackBatch  Boolean     @default(false)
  minQuantity Decimal?    @db.Decimal(18, 4) // минимальный остаток (алерт)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  batches    Batch[]
  stocks     Stock[]
  movements  StockMovement[]

  @@map("products")
}

model Warehouse {
  id        String         @id @default(cuid())
  name      String
  type      WarehouseType  @default(MAIN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  stocks    Stock[]
  movements StockMovement[]

  @@map("warehouses")
}

model Batch {
  id           String    @id @default(cuid())
  productId    String
  expiryDate   DateTime?
  batchNumber  String?
  createdAt    DateTime  @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocks    Stock[]
  movements StockMovement[]

  @@map("batches")
}

model Stock {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  batchId     String?
  quantity    Decimal  @default(0) @db.Decimal(18, 4)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batch     Batch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@unique([productId, warehouseId, batchId])
  @@map("stocks")
}

model StockDocument {
  id           String              @id @default(cuid())
  type         StockDocumentType
  number       String              @unique
  documentDate DateTime            @default(now())
  status       StockDocumentStatus @default(DRAFT)
  comment      String?
  createdById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  movements StockMovement[]

  @@map("stock_documents")
}

model StockMovement {
  id          String            @id @default(cuid())
  documentId  String
  type        StockMovementType
  productId   String
  warehouseId String
  batchId     String?
  quantity    Decimal           @db.Decimal(18, 4)
  createdAt   DateTime          @default(now())

  document  StockDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batch     Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

// ============================================
// Редактируемый контент сайта
// ============================================

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_content")
}

// ============================================
// RAG: база знаний
// ============================================

model KnowledgeChunk {
  id        String   @id @default(cuid())
  source    String   // "service", "procedure", "faq", "article", "dental_info"
  sourceId  String?
  title     String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_chunks")
}

// ============================================
// Соцсети: история постов
// ============================================

model SocialPost {
  id          String    @id @default(cuid())
  content     String    @db.Text
  imageUrl    String?
  platforms   String[]  // ["telegram", "vk"]
  status      String    @default("draft")
  publishedAt DateTime?
  results     Json?
  error       String?
  createdAt   DateTime  @default(now())

  @@map("social_posts")
}

// ============================================
// Ежедневник (планировщик)
// ============================================

model PlannerNote {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  time      String?  // "14:30"
  title     String
  text      String?  @db.Text
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("planner_notes")
}

// ============================================
// Аудит-лог (журнал действий)
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "patient.create", "appointment.update", "payment.create"
  entity    String   // "patient", "appointment", etc.
  entityId  String?
  details   Json?    // подробности изменения
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
